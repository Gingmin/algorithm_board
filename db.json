      "problemId": "prob-rotate-array",
      "attemptNumber": 1,
      "code": "function solution(nums, k) {\n  // 여기에 코드를 작성하세요\n  const rm = k % nums.length;\n\n  const arr = Array.from({ length: nums.length }, () => 0);\n\n  for (let i = 0; i < nums.length; i++) {\n    if (i + rm >= nums.length) {\n      arr[i + rm - nums.length] = nums[i];\n    } else {\n      arr[i + rm] = nums[i];\n    }\n  }\n  return arr;\n}",
